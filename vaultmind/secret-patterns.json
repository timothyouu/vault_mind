[
  {
    "pattern_id": "supabase-service-role-jwt",
    "description": "Supabase service_role JWT",
    "regex": "eyJ[A-Za-z0-9_-]{20,}\\.[A-Za-z0-9_-]{20,}\\.[A-Za-z0-9_-]{20,}"
  },
  {
    "pattern_id": "generic-jwt",
    "description": "Generic JWT (three base64url segments separated by dots)",
    "regex": "eyJ[A-Za-z0-9_-]{4,}\\.[A-Za-z0-9_-]{4,}\\.[A-Za-z0-9_-]{4,}"
  },
  {
    "pattern_id": "aws-access-key-id",
    "description": "AWS access key ID",
    "regex": "AKIA[0-9A-Z]{16}"
  },
  {
    "pattern_id": "aws-secret-access-key",
    "description": "AWS secret access key",
    "regex": "aws_secret_access_key\\s*=\\s*[A-Za-z0-9/+]{40}"
  },
  {
    "pattern_id": "github-pat",
    "description": "GitHub personal access token",
    "regex": "(?:ghp_[A-Za-z0-9]{36}|github_pat_[A-Za-z0-9_]{82})"
  },
  {
    "pattern_id": "openai-api-key",
    "description": "OpenAI API key",
    "regex": "sk-(?:proj-)?[A-Za-z0-9]{48}"
  },
  {
    "pattern_id": "anthropic-api-key",
    "description": "Anthropic API key",
    "regex": "sk-ant-[A-Za-z0-9_-]{32,}"
  },
  {
    "pattern_id": "private-key-header",
    "description": "PEM private key header",
    "regex": "-----BEGIN (?:RSA |EC )?PRIVATE KEY-----"
  },
  {
    "pattern_id": "generic-high-entropy",
    "description": "High-entropy quoted string (40+ hex chars)",
    "regex": "[\"'][0-9a-fA-F]{40,}[\"']"
  }
]
