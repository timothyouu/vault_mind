# ── Required ──────────────────────────────────────────────────────────────────
# Anthropic API key — used by Scribe (P2) and Evals agents
ANTHROPIC_API_KEY=sk-ant-...

# ── Redis ─────────────────────────────────────────────────────────────────────
# Connection URL for Redis (queue + event bus + vector memory)
# Default: redis://localhost:6379 — override if using a remote instance
REDIS_URL=redis://localhost:6379

# ── Vault path ────────────────────────────────────────────────────────────────
# Override the vault directory (default: ./vault relative to project root)
# VAULTMIND_VAULT_ROOT=./vault

# ── Arize observability (optional) ────────────────────────────────────────────
# Leave unset for local dev without observability.
# Set VAULTMIND_ARIZE_REQUIRED=1 to make missing keys a hard error.
# ARIZE_SPACE_KEY=
# ARIZE_API_KEY=
# VAULTMIND_ARIZE_REQUIRED=

# ── Fetch.AI bridge (webapp/agent_bridge.py) ──────────────────────────────────
# These live in webapp/.env.local (loaded by agent_bridge.py via python-dotenv)
# AGENTVERSE_KEY=
# AGENT_SEED_PHRASE=vaultmind-orchestrator-seed-phrase-01
# AGENT_SECRET_KEY=vaultmind-bridge-seed-phrase-01
# BRIDGE_PORT=8002
# FLASK_PORT=5002
